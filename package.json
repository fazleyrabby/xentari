{
  "name": "xentari",
  "version": "1.0.0",
  "description": "**Xentari is a deterministic, local-first AI development system that executes coding tasks through structured pipelines instead of chat.**",
  "keywords": [
    "cli",
    "ai"
  ],
  "homepage": "https://github.com/fazleyrabby/xentari#readme",
  "bugs": {
    "url": "https://github.com/fazleyrabby/xentari/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fazleyrabby/xentari.git"
  },
  "license": "ISC",
  "author": "fazley",
  "type": "module",
  "main": "index.js",
  "bin": {
    "xen": "bin/xen.js"
  },
  "scripts": {
    "start": "node bin/xen.js",
    "build": "tsc",
    "test:run": "tsx tests/run.ts",
    "test:update": "tsx tests/run.ts --update",
    "test:stress": "tsx tests/stress.ts",
    "test:plans": "tsx tests/plan_harness.ts",
    "test:update:plans": "tsx tests/plan_harness.ts --update",
    "test:execution": "tsx tests/execution_harness.ts",
    "test:update:execution": "tsx tests/execution_harness.ts --update",
    "test:adapters": "tsx tests/adapter_harness.ts",
    "test:update:adapters": "tsx tests/adapter_harness.ts --update"
  },
  "dependencies": {
    "body-parser": "^2.2.2",
    "cors": "^2.8.6",
    "diff": "^7.0.0",
    "express": "^5.2.1",
    "glob": "^10.3.10",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "directories": {
    "test": "tests"
  }
}
